# ================================
# PANZZSTORE - BOT CONFIGURATION
# ================================

# Telegram Bot
STORE_NAME=NamaTokoMu
ADMIN_USERNAME=usernameadmin
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_FROM_BOTFATHER
ADMIN_TELEGRAM_ID=YOUR_ADMIN_TELEGRAM_ID

# Pakasir Payment Gateway
PAKASIR_API_KEY=YOUR_PAKASIR_API_KEY
PAKASIR_SLUG=YOUR_PAKASIR_SLUG

# Server
PORT=3000
BASE_URL=https://your-domain.com

# Firebase Configuration
# Anda bisa menggunakan salah satu dari 2 opsi berikut:
# Opsi 1: Letakkan file serviceAccountKey.json (dari Firebase Console) di folder utama project.
# Opsi 2 (Rekomendasi untuk Railway): Masukkan seluruh isi JSON serviceAccountKey.json ke variabel di bawah sebagai string satu baris:
FIREBASE_SERVICE_ACCOUNT={"type": "service_account", "project_id": "...", ...}

# Admin Dashboard
# (Tidak ada Web Dashboard lagi, fitur Admin 100% dipindahkan ke Telegram Mini App)
ADMIN_SECRET_KEY=YOUR_SECRET_KEYsecret_jwt_key_2024

# ─── TELEGRAM STORAGE ──────────────────────────────────────────────────────────
# Akun-akun TikTok disimpan dengan cara diteruskan ke Telegram Private Channel.
# 
# Cara setup:
# 1. Buat Channel Telegram Private baru
# 2. Masukkan bot ke dalam Channel tersebut sebagai Admin
# 3. Ketik pesan apapun di dalam channel, lalu forward ke bot @userinfobot untuk melihat ID-nya
# 4. Copy ID Channel (biasanya berawalan -100) ke bawah ini:

STORAGE_CHANNEL_ID=YOUR_STORAGE_CHANNEL_ID
