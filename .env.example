# ================================
# PANZZSTORE - BOT CONFIGURATION
# ================================

# Telegram Bot
STORE_NAME=NamaTokoMu
ADMIN_USERNAME=usernameadmin
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_FROM_BOTFATHER
ADMIN_TELEGRAM_ID=YOUR_ADMIN_TELEGRAM_ID

# Pakasir Payment Gateway
PAKASIR_API_KEY=YOUR_PAKASIR_API_KEY
PAKASIR_BASE_URL=https://pakasir.com/api

# Server
PORT=3000
BASE_URL=https://your-domain.com

# Firebase
# Letakkan file serviceAccountKey.json (dari Firebase Console) di folder utama (satu folder dengan file .env ini).
# File .env ini tidak butuh diisi key Firebase manual lagi karena sistem otomatis membaca serviceAccountKey.json.
# Namun, pastikan mengisi BUCKET URL di bawah ini untuk penyimpanan file (cari di menu Storage Firebase):
FIREBASE_STORAGE_BUCKET=namaproject.appspot.com

# Admin Dashboard
# (Tidak ada Web Dashboard lagi, fitur Admin 100% dipindahkan ke Telegram Mini App)
ADMIN_SECRET_KEY=YOUR_SECRET_KEYsecret_jwt_key_2024
